.claude/settings.local.json

# Internal-only docs & editor config — excluded from the public repo and
# expunged from history during the pre-public sanitization (2026-06-19).
# They may legitimately exist locally for development (e.g. CLAUDE.md for
# agent context, .cursor/ for the IDE), but MUST NOT be committed — ignoring
# them here prevents accidentally re-introducing the sanitized content.
CLAUDE.md
.cursor/
.cursorrules
marketing/
docs/PRIVACY_DISCUSSION.md
