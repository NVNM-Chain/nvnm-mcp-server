# Sensitive values for the MCP server. Copy to secret.yaml, fill in
# real values, and add to kustomization.yaml under resources.
# DO NOT commit secret.yaml -- it is .gitignore'd alongside other
# operator-local material.
#
# In production, prefer a real secret manager (External Secrets,
# SOPS-encrypted YAML, Vault Agent) over a plaintext Secret. Plain k8s
# Secrets are base64-encoded, not encrypted, and are stored in etcd
# unless the cluster has encryption-at-rest enabled cluster-wide.
apiVersion: v1
kind: Secret
metadata:
  name: inveniam-mcp-server-secret
  labels:
    app.kubernetes.io/name: inveniam-mcp-server
    app.kubernetes.io/component: mcp-server
    app.kubernetes.io/part-of: inveniam
type: Opaque
stringData:
  # The RPC URL is treated as sensitive because it commonly embeds an
  # API key or per-tenant credential in the query string.
  INVENIAM_EVM_RPC_URL: "https://rpc.example.com"

  # ONE of the two API-key auth modes below. Comment out the unused one.
  #
  # 1) File-backed multi-key store. Pair this with a mounted file at
  #    MCP_API_KEYS_FILE -- see the deployment patch below for how to
  #    mount it from a separate Secret with the JSON payload.
  MCP_API_KEYS_FILE: "/var/run/secrets/inveniam/keys.json"
  #
  # 2) Single bearer key (test/dev convenience; no rotation, no roles).
  # MCP_API_KEY: "REPLACE_WITH_A_32_BYTE_BASE64URL_VALUE" # pragma: allowlist secret -- placeholder

  # Admin REST API key. Single shared bearer. Required only when
  # ADMIN_API_KEY is set in env; the admin server binds to
  # 127.0.0.1:8081 by default -- expose via ADMIN_API_ADDR=:8081 only
  # if a separate NetworkPolicy locks ingress to in-cluster admins.
  ADMIN_API_KEY: "REPLACE_WITH_A_32_BYTE_BASE64URL_VALUE" # pragma: allowlist secret -- placeholder

  # FusionAuth (alternative to apikey provider).
  # FUSIONAUTH_APPLICATION_ID: "00000000-0000-0000-0000-000000000000"
---
# The keys file mounted at MCP_API_KEYS_FILE. JSON array of KeyEntry.
# In production, generate this with `key-mgmt` and store via External
# Secrets / SOPS / Vault rather than checking in.
apiVersion: v1
kind: Secret
metadata:
  name: inveniam-mcp-server-keys
  labels:
    app.kubernetes.io/name: inveniam-mcp-server
    app.kubernetes.io/component: mcp-server
    app.kubernetes.io/part-of: inveniam
type: Opaque
stringData:
  keys.json: |
    [
      {
        "id": "example-client",
        "key": "REPLACE_WITH_A_32_BYTE_BASE64URL_VALUE" # pragma: allowlist secret -- placeholder,
        "enabled": true,
        "created_at": "2026-05-12T00:00:00Z",
        "write_approval": "required",
        "roles": ["reader"]
      }
    ]
