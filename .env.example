# NVNM Chain MCP Server -- environment variables template.
#
# Copy to .env and fill in real values. .env is gitignored.
# See docs/RUNBOOK.md for the full env-var reference and migration notes.
#
# Anything marked PLACEHOLDER must be replaced before the server will run.

# ---------------------------------------------------------------------------
# Required -- chain config (read at startup; legacy INVENIAM_* is rejected)
# ---------------------------------------------------------------------------
NVNM_EVM_RPC_URL=https://evm.testnet.nvnmchain.io
NVNM_CHAIN_ID=787111
NVNM_CHAIN_ENVIRONMENT=testnet
ANCHOR_ABI_PATH=abi/anchoring.json

# ---------------------------------------------------------------------------
# Optional -- archive node for historical queries
# ---------------------------------------------------------------------------
# NVNM_EVM_ARCHIVE_RPC_URL=

# ---------------------------------------------------------------------------
# Transport (stdio for local MCP clients; http for remote/production)
# ---------------------------------------------------------------------------
MCP_TRANSPORT=http
MCP_HTTP_ADDR=:8180
METRICS_ADDR=:9190

# ---------------------------------------------------------------------------
# Authentication (HTTP transport)
# ---------------------------------------------------------------------------
# AUTH_PROVIDER picks the validator: "apikey" (default) or "fusionauth".
AUTH_PROVIDER=apikey

# API-key provider -- pick ONE of MCP_API_KEYS_FILE (multi-key store,
# production path) or MCP_API_KEY (single-key dev override).
MCP_API_KEYS_FILE=.mcp-keys.json
# MCP_API_KEY=PLACEHOLDER
# Roles for the single static MCP_API_KEY (comma-separated).
# REQUIRED when MCP_API_KEY is set -- the server refuses to boot without it.
# Valid roles: reader, writer, admin, automation.
# MCP_API_KEY_ROLES=reader,writer,admin,automation

# HMAC pepper for API-key hashing (optional; Phase 2 feature).
# Purpose: a server-side secret that makes a database-only key-store dump
# non-reversible even against offline brute-force. When set, newly issued keys
# are stored as HMAC-SHA256(key, pepper) (hash_version 1). Legacy v0 keys
# (plain SHA-256) continue to authenticate unchanged via versioned candidate
# lookup. Persisted re-hashing of legacy keys to v1 lands with the Postgres
# backend (Phase 3). Setting KEY_HMAC_PEPPER_PREVIOUS without KEY_HMAC_PEPPER
# fails boot (ErrPepperPreviousWithoutActive). Wire a long random secret from
# Vault / k8s Secret / AWS Secrets Manager -- never commit a real value here.
# KEY_HMAC_PEPPER=
# KEY_HMAC_PEPPER_PREVIOUS=   # one rotation window; requires KEY_HMAC_PEPPER

# ---------------------------------------------------------------------------
# Key-store backend (Phase 3)
# ---------------------------------------------------------------------------
# Selects where issued API keys are persisted. Default is "file" (the
# MCP_API_KEYS_FILE JSON store described above). Set to "postgres" to use the
# Postgres backend for multi-replica deployments where all replicas must share
# a single authoritative key store.
#
# KEY_STORE_BACKEND=file        # "file" (default) or "postgres"
# KEY_STORE_DSN=                # required when KEY_STORE_BACKEND=postgres
#   When KEY_STORE_BACKEND=postgres and AUTH_PROVIDER=apikey, KEY_HMAC_PEPPER
#   is REQUIRED (boot fails with ErrPepperRequired without it). Migrations run
#   automatically at boot under a pg_advisory_lock (safe across concurrent
#   replicas). expires_at is stored in the schema but expiry enforcement is
#   deferred to Phase 4 -- keys do not expire today.

# Admin REST API for runtime key management (separate port).
# ADMIN_API_KEY=PLACEHOLDER
# ADMIN_API_ADDR=:8081

# FusionAuth provider (only when AUTH_PROVIDER=fusionauth)
# FUSIONAUTH_URL=https://auth.example.com
# FUSIONAUTH_APPLICATION_ID=PLACEHOLDER
# FUSIONAUTH_ISSUER=
# JWT_CLOCK_SKEW=60s
# JWT_ROLES_CLAIM=roles
# MCP_CLIENT_ID_HMAC_KEY: REQUIRED when AUTH_PROVIDER=fusionauth. Keys the
# one-way transform applied to the JWT sub before it is logged as client_id,
# so the email-reversible sub never reaches a log sink. Use a long random
# secret; startup fails loud if unset. Rotating it re-randomizes client_id
# (breaks historical log correlation, which is acceptable).
# MCP_CLIENT_ID_HMAC_KEY=PLACEHOLDER_LONG_RANDOM_SECRET

# Origin / CORS allowlist
# NVNM_ALLOWED_ORIGINS=https://localhost:3000

# ---------------------------------------------------------------------------
# Keyless reads (HTTP transport only)
# ---------------------------------------------------------------------------
# When true, read tools (anchor verification, EVM reads, overview / wizard /
# wallet-status helpers) may be called without an Authorization header; write
# tools (evm_send_raw_transaction) still require a Bearer token. Default
# false preserves the pre-9.16 "all-or-nothing" auth posture. Ignored under
# stdio transport (a startup warning is logged if set).
MCP_KEYLESS_READS=false
# Per-source-IP rate limit for anonymous reads. Operator-enforced invariant:
# this MUST be tighter than the per-client write limits (MCP_RATE_LIMIT /
# MCP_RATE_BURST). Defaults: 5 rps / 5 burst.
MCP_ANON_RATE_LIMIT=5
MCP_ANON_RATE_BURST=5

# ---------------------------------------------------------------------------
# Write tools (off by default; gated by RBAC role + ENABLE_WRITE_TOOLS)
# ---------------------------------------------------------------------------
ENABLE_WRITE_TOOLS=false

# ---------------------------------------------------------------------------
# Integration-test credentials (used by `make test-integration` only)
# Real values are testnet-only and never go in committed files.
# ---------------------------------------------------------------------------
# NVNM_TEST_PRIVATE_KEY=PLACEHOLDER
# NVNM_TEST_ADDRESS=PLACEHOLDER

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_PROMETHEUS=true
ENABLE_STDOUT_TELEMETRY=false
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_SERVICE_NAME=nvnm-mcp-server
# OTEL_TRACE_SAMPLE_RATIO=1.0
